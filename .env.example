REPORT_PROVIDER=local
REPORT_FALLBACK_PROVIDER=

# Local Ollama provider
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:31b

# Gemini provider. Keep the key only on the server or local worker.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Control plane connection
CONTROL_PLANE_URL=https://example.com
WORKER_TOKEN=
WORKER_ID=majd-local-01
WORKER_POLL_SECONDS=5
WORKER_MAX_JOBS=1

# Deployable control-plane API
CONTROL_PLANE_ADMIN_TOKEN=replace-with-a-long-random-admin-token
CONTROL_PLANE_DB=./data/control-plane.sqlite3

# Shared report engine files
REPORT_SYSTEM_PROMPT=./prompts/report-system-prompt.txt
REPORT_RESPONSE_SCHEMA=./prompts/report-response.schema.json
