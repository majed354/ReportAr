{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["version", "mode", "status", "user_message", "questions", "audit", "decisions", "report", "chart_intents"],
  "properties": {
    "version": {"const": "1.0"},
    "mode": {"enum": ["guided", "fast"]},
    "status": {"enum": ["needs_user_input", "ready_to_render", "blocked"]},
    "user_message": {"type": "string"},
    "questions": {
      "type": "array",
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["id", "question", "reason", "required", "options"],
        "properties": {
          "id": {"type": "string"},
          "question": {"type": "string"},
          "reason": {"type": "string"},
          "required": {"type": "boolean"},
          "options": {
            "type": "array",
            "minItems": 2,
            "maxItems": 4,
            "items": {
              "type": "object",
              "required": ["id", "label", "recommended"],
              "properties": {
                "id": {"type": "string"},
                "label": {"type": "string"},
                "recommended": {"type": "boolean"}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "audit": {
      "type": "object",
      "required": ["issues", "missing_information", "contradictions", "rejected_instructions"],
      "properties": {
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["code", "severity", "message", "evidence", "suggested_action"],
            "properties": {
              "code": {"type": "string"},
              "severity": {"enum": ["info", "warning", "critical"]},
              "message": {"type": "string"},
              "evidence": {"type": "string"},
              "suggested_action": {"type": "string"}
            },
            "additionalProperties": false
          }
        },
        "missing_information": {"type": "array", "items": {"type": "string"}},
        "contradictions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["field", "reported", "calculated", "note"],
            "properties": {
              "field": {"type": "string"},
              "reported": {"type": "string"},
              "calculated": {"type": "string"},
              "note": {"type": "string"}
            },
            "additionalProperties": false
          }
        },
        "rejected_instructions": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "decisions": {
      "type": "object",
      "required": ["report_type", "theme_id", "theme_reason", "use_logo", "use_cover_image", "background_usage", "decision_notes"],
      "properties": {
        "report_type": {"enum": ["executive", "official", "academic", "heritage", "data", "general"]},
        "theme_id": {"enum": ["executive-modern", "official-formal", "academic-clean", "heritage-elegant", "data-dashboard", "minimal-neutral"]},
        "theme_reason": {"type": "string"},
        "use_logo": {"type": "boolean"},
        "use_cover_image": {"type": "boolean"},
        "background_usage": {"enum": ["plain", "cover_only", "cover_and_section_dividers_only", "soft_surface"]},
        "decision_notes": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "report": {
      "type": ["object", "null"],
      "required": ["title", "subtitle", "executive_summary", "sections", "kpis", "recommendations", "unresolved_notes"],
      "properties": {
        "title": {"type": "string"},
        "subtitle": {"type": "string"},
        "executive_summary": {"type": "string"},
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["heading", "body"],
            "properties": {
              "heading": {"type": "string"},
              "body": {"type": "string"}
            },
            "additionalProperties": false
          }
        },
        "kpis": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "value", "unit"],
            "properties": {
              "label": {"type": "string"},
              "value": {"type": "number"},
              "unit": {"type": "string"}
            },
            "additionalProperties": false
          }
        },
        "recommendations": {"type": "array", "items": {"type": "string"}},
        "unresolved_notes": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "chart_intents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "title", "labels", "values", "start", "changes", "reported_end", "calculated_end", "stages", "reason"],
        "properties": {
          "id": {"type": "string"},
          "kind": {"enum": ["distribution_four", "column_comparison", "executive_scorecard", "time_trend", "cumulative_change", "project_milestones", "long_label_comparison"]},
          "title": {"type": "string"},
          "labels": {"type": "array", "items": {"type": "string"}},
          "values": {"type": "array", "items": {"type": "number"}},
          "start": {"type": ["number", "null"]},
          "changes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["label", "value"],
              "properties": {
                "label": {"type": "string"},
                "value": {"type": "number"}
              },
              "additionalProperties": false
            }
          },
          "reported_end": {"type": ["number", "null"]},
          "calculated_end": {"type": ["number", "null"]},
          "stages": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["label", "date"],
              "properties": {
                "label": {"type": "string"},
                "date": {"type": ["string", "null"]}
              },
              "additionalProperties": false
            }
          },
          "reason": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
